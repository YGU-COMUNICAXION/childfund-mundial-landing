---
import { Image } from "astro:assets";
import nna from "@assets/img/nna.png";
import wave from "@assets/img/wave.png";
---

<section id="childfund" class="relative bg-white px-8 pb-20 pt-14 md:px-16 md:pb-32 md:pt-28">
  <Image src={wave} alt="" class="pointer-events-none absolute left-1/2 top-0
  h-16 w-screen max-w-none -translate-x-1/2 -translate-y-full
  rotate-180 object-cover md:h-28" />

  <div class="mx-auto grid max-w-7xl items-center gap-12 md:grid-cols-2 md:gap-20 xl:gap-36">
    <Image src={nna} alt="Niñas y niños de ChildFund México" class="mx-auto size-52 object-cover md:size-112 xl:size-120" />

    <div class="mx-auto max-w-2xl text-center">
      <h2 class="m-0 text-2xl font-bold leading-none tracking-widest md:text-5xl md:leading-none">
        En ChildFund México<br />
        <span class="text-sm md:text-3xl">(Fondo para niños de México A.C.)</span>
      </h2>
      <p class="m-0 mt-5 text-sm font-medium leading-snug md:text-3xl md:leading-tight">
        llevamos trabajando más de 50 años en México, junto a las comunidades para construir entornos más seguros para la niñez.
      </p>
      <a href="#registro" class="mt-5 inline-flex text-sm font-bold leading-tight text-childfund-green underline decoration-childfund-green decoration-[0.13em] underline-offset-2 md:text-3xl">
        SABER MÁS
      </a>
    </div>
  </div>
</section>
